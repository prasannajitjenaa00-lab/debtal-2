{
  "include": ["src/**/*.js", "src/**/*.jsx", "vite.config.js", "eslint.config.js"],
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "checkJs": false,

    /* Bundler mode */
    "moduleResolution": "Bundler",
    "allowJs": true,

    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
